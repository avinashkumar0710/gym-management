<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plans - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans" class="active"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Membership Plans</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Add New Plan</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/plans/add" class="row">
                        <div class="form-group col-md-3">
                            <label>Plan Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Duration (days)</label>
                            <input type="number" name="duration" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Price ($)</label>
                            <input type="number" step="0.01" name="price" class="form-control" required>
                        </div>
                        <div class="form-group col-md-3">
                            <label>Description</label>
                            <input type="text" name="description" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">Add Plan</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="row mt-4">
                <% if(plans.length > 0) { %>
                    <% plans.forEach(plan => { %>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h4><%= plan.name %></h4>
                                    <h2 class="text-primary">$<%= parseFloat(plan.price).toFixed(2) %></h2>
                                    <p><%= plan.duration %> Days</p>
                                    <p class="text-muted"><%= plan.description || '' %></p>
                                    <form method="POST" action="/admin/plans/delete" class="d-inline">
                                        <input type="hidden" name="id" value="<%= plan.id %>">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this plan?')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center">
                        <p>No plans found. Add one above!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>

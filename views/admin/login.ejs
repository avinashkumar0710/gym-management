<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - FitZone Gym</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <h2><i class="fas fa-dumbbell"></i> FitZone Admin</h2>
            <% if(error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <form method="POST" action="/admin/login">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Login</button>
            </form>
            <p class="mt-3 text-center"><small>Default: admin / admin123</small></p>
            <p class="mt-2 text-center"><a href="/" class="text-white">Back to Website</a></p>
        </div>
    </div>
</body>
</html>

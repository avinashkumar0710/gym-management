<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payments - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments" class="active"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Payments Management</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="alert alert-success">
                <strong>Total Revenue:</strong> $<%= parseFloat(totalRevenue).toFixed(2) %>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Record Payment</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/payments/add" class="row">
                        <div class="form-group col-md-2">
                            <label>Member</label>
                            <select name="member_id" class="form-control">
                                <option value="">Select Member</option>
                                <% members.forEach(m => { %>
                                    <option value="<%= m.id %>"><%= m.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Amount ($)</label>
                            <input type="number" step="0.01" name="amount" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Date</label>
                            <input type="date" name="payment_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Method</label>
                            <select name="payment_method" class="form-control">
                                <option value="Cash">Cash</option>
                                <option value="Card">Card</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="UPI">UPI</option>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Status</label>
                            <select name="status" class="form-control">
                                <option value="pending">Pending</option>
                                <option value="paid">Paid</option>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">Add Payment</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>All Payments</h5>
                </div>
                <div class="card-body">
                    <table class="table table-responsive">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Member</th>
                                <th>Amount</th>
                                <th>Date</th>
                                <th>Method</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(payments.length > 0) { %>
                                <% payments.forEach(p => { %>
                                    <tr>
                                        <td><%= p.id %></td>
                                        <td><%= p.member_name || 'N/A' %></td>
                                        <td>$<%= parseFloat(p.amount).toFixed(2) %></td>
                                        <td><%= p.payment_date ? new Date(p.payment_date).toLocaleDateString() : '-' %></td>
                                        <td><%= p.payment_method || '-' %></td>
                                        <td>
                                            <select class="form-control form-control-sm payment-status" data-id="<%= p.id %>">
                                                <option value="paid" <%= p.status === 'paid' ? 'selected' : '' %>>Paid</option>
                                                <option value="pending" <%= p.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            </select>
                                        </td>
                                        <td>
                                            <form method="POST" action="/admin/payments/delete" class="d-inline">
                                                <input type="hidden" name="id" value="<%= p.id %>">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this payment?')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="7" class="text-center">No payments found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.payment-status').change(function() {
                const id = $(this).data('id');
                const status = $(this).val();
                $.post('/admin/payments/update-status', { id, status });
            });
        });
    </script>
</body>
</html>

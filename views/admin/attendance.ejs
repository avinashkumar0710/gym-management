<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance" class="active"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Attendance Tracking</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Mark Attendance</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/attendance/mark" class="row">
                        <div class="form-group col-md-3">
                            <label>Member</label>
                            <select name="member_id" class="form-control" required>
                                <option value="">Select Member</option>
                                <% members.forEach(m => { %>
                                    <option value="<%= m.id %>"><%= m.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Date</label>
                            <input type="date" name="date" class="form-control" value="<%= today %>">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Status</label>
                            <select name="status" class="form-control">
                                <option value="present">Present</option>
                                <option value="absent">Absent</option>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">Mark</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>Today's Attendance (<%= today %>)</h5>
                </div>
                <div class="card-body">
                    <table class="table table-responsive">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Member</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(attendance.length > 0) { %>
                                <% attendance.forEach(a => { %>
                                    <tr>
                                        <td><%= a.id %></td>
                                        <td><%= a.member_name %></td>
                                        <td><%= a.date ? new Date(a.date).toLocaleDateString() : '-' %></td>
                                        <td><span class="badge badge-<%= a.status === 'present' ? 'success' : 'danger' %>"><%= a.status %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="4" class="text-center">No attendance records for today</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

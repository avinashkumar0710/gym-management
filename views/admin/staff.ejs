<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff" class="active"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Staff Management</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Add New Staff</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/staff/add" class="row">
                        <div class="form-group col-md-2">
                            <label>Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Role</label>
                            <select name="role" class="form-control" required>
                                <option value="Trainer">Trainer</option>
                                <option value="Receptionist">Receptionist</option>
                                <option value="Manager">Manager</option>
                                <option value="Cleaner">Cleaner</option>
                                <option value="Security">Security</option>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Phone</label>
                            <input type="text" name="phone" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Salary ($)</label>
                            <input type="number" step="0.01" name="salary" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Join Date</label>
                            <input type="date" name="join_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                            <button type="submit" class="btn btn-primary btn-block mt-2">Add Staff</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>All Staff</h5>
                </div>
                <div class="card-body">
                    <table class="table table-responsive">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Salary</th>
                                <th>Join Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(staff.length > 0) { %>
                                <% staff.forEach(s => { %>
                                    <tr>
                                        <td><%= s.id %></td>
                                        <td><%= s.name %></td>
                                        <td><span class="badge badge-info"><%= s.role %></span></td>
                                        <td><%= s.email || '-' %></td>
                                        <td><%= s.phone || '-' %></td>
                                        <td>$<%= parseFloat(s.salary || 0).toFixed(2) %></td>
                                        <td><%= s.join_date ? new Date(s.join_date).toLocaleDateString() : '-' %></td>
                                        <td>
                                            <form method="POST" action="/admin/staff/delete" class="d-inline">
                                                <input type="hidden" name="id" value="<%= s.id %>">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this staff?')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="8" class="text-center">No staff found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

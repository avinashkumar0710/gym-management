<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members" class="active"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Members Management</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Add New Member</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/members/add" class="row">
                        <div class="form-group col-md-2">
                            <label>Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Phone</label>
                            <input type="text" name="phone" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Plan</label>
                            <select name="plan_id" class="form-control">
                                <option value="">Select Plan</option>
                                <% plans.forEach(plan => { %>
                                    <option value="<%= plan.id %>"><%= plan.name %> - $<%= parseFloat(plan.price).toFixed(2) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Join Date</label>
                            <input type="date" name="join_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        <div class="form-group col-md-2">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">Add Member</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>All Members</h5>
                </div>
                <div class="card-body">
                    <table class="table table-responsive">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Plan</th>
                                <th>Join Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(members.length > 0) { %>
                                <% members.forEach(member => { %>
                                    <tr>
                                        <td><%= member.id %></td>
                                        <td><%= member.name %></td>
                                        <td><%= member.email || '-' %></td>
                                        <td><%= member.phone || '-' %></td>
                                        <td><%= member.plan_name || '-' %></td>
                                        <td><%= member.join_date ? new Date(member.join_date).toLocaleDateString() : '-' %></td>
                                        <td>
                                            <select class="form-control form-control-sm status-select" data-id="<%= member.id %>">
                                                <option value="active" <%= member.status === 'active' ? 'selected' : '' %>>Active</option>
                                                <option value="expired" <%= member.status === 'expired' ? 'selected' : '' %>>Expired</option>
                                                <option value="pending" <%= member.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            </select>
                                        </td>
                                        <td>
                                            <form method="POST" action="/admin/members/delete" class="d-inline">
                                                <input type="hidden" name="id" value="<%= member.id %>">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this member?')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="8" class="text-center">No members found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.status-select').change(function() {
                const id = $(this).data('id');
                const status = $(this).val();
                $.post('/admin/members/update-status', { id, status });
            });
        });
    </script>
</body>
</html>

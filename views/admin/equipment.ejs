<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equipment - FitZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <h4><i class="fas fa-dumbbell"></i> FitZone</h4>
            <a href="/admin"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin/members"><i class="fas fa-users"></i> Members</a>
            <a href="/admin/plans"><i class="fas fa-tags"></i> Plans</a>
            <a href="/admin/staff"><i class="fas fa-user-tie"></i> Staff</a>
            <a href="/admin/attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            <a href="/admin/payments"><i class="fas fa-money-bill"></i> Payments</a>
            <a href="/admin/equipment" class="active"><i class="fas fa-dumbbell"></i> Equipment</a>
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>

        <div class="content">
            <div class="top-bar">
                <h3>Equipment Management</h3>
                <a href="/" class="btn btn-sm btn-secondary">Back to Website</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Add New Equipment</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/equipment/add" class="row">
                        <div class="form-group col-md-2">
                            <label>Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Quantity</label>
                            <input type="number" name="quantity" class="form-control" value="1">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Status</label>
                            <select name="status" class="form-control">
                                <option value="available">Available</option>
                                <option value="maintenance">Maintenance</option>
                            </select>
                        </div>
                        <div class="form-group col-md-2">
                            <label>Purchase Date</label>
                            <input type="date" name="purchase_date" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>Maintenance Date</label>
                            <input type="date" name="maintenance_date" class="form-control">
                        </div>
                        <div class="form-group col-md-2">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">Add Equipment</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>All Equipment</h5>
                </div>
                <div class="card-body">
                    <table class="table table-responsive">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Purchase Date</th>
                                <th>Maintenance Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(equipment.length > 0) { %>
                                <% equipment.forEach(e => { %>
                                    <tr>
                                        <td><%= e.id %></td>
                                        <td><%= e.name %></td>
                                        <td><%= e.quantity %></td>
                                        <td><span class="badge badge-<%= e.status === 'available' ? 'success' : 'warning' %>"><%= e.status %></span></td>
                                        <td><%= e.purchase_date ? new Date(e.purchase_date).toLocaleDateString() : '-' %></td>
                                        <td><%= e.maintenance_date ? new Date(e.maintenance_date).toLocaleDateString() : '-' %></td>
                                        <td>
                                            <form method="POST" action="/admin/equipment/delete" class="d-inline">
                                                <input type="hidden" name="id" value="<%= e.id %>">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this equipment?')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="7" class="text-center">No equipment found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
